{
  "id": "bot-webhook-plugin",
  "name": "Bot Webhook",
  "description": "This plugin allows you to send a webhook when a bot receives a message.",
  "icon_path": "assets/starter-template-icon.svg",
  "version": "0.4.2",
  "min_server_version": "6.2.1",
  "server": {
    "executables": {
      "linux-amd64": "server/dist/plugin-linux-amd64",
      "linux-arm64": "server/dist/plugin-linux-arm64",
      "darwin-amd64": "server/dist/plugin-darwin-amd64",
      "darwin-arm64": "server/dist/plugin-darwin-arm64",
      "windows-amd64": "server/dist/plugin-windows-amd64.exe"
    }
  },
  "settings_schema": {
    "header": "Bot Webhook Plugin 0.4.2<br>For each bot: enter the <b>Username</b> (@username) and save — the <b>User ID</b> will be resolved automatically.",
    "settings": [
      {
        "key": "BotUsername",
        "display_name": "Bot 1 Username",
        "type": "text",
        "help_text": "The bot username (e.g. @my-bot). The User ID will be resolved automatically on save.",
        "placeholder": "@username",
        "default": ""
      },
      {
        "key": "BotUserID",
        "display_name": "Bot 1 User ID",
        "type": "text",
        "help_text": "Auto-populated from the username above. Do not edit manually.",
        "placeholder": "",
        "default": ""
      },
      {
        "key": "WebhookURL",
        "display_name": "Bot 1 Webhook URL",
        "type": "text",
        "help_text": "The URL to send the HTTP request to when bot 1 receives a message.",
        "placeholder": "Enter the webhook URL",
        "default": ""
      },
      {
        "key": "BearerToken",
        "display_name": "Bot 1 Bearer Token",
        "type": "text",
        "help_text": "The bearer token to use for bot 1's HTTP request.",
        "placeholder": "Enter the Bearer token",
